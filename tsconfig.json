{
	"extends": "@total-typescript/tsconfig/tsc/dom/library",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"jsx": "react-jsx",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2022"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
